# --- Database (Postgres) ---
# Runtime (pooled) connection string. Neon example:
#   postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/nmta?schema=public"
# Direct (non-pooled) connection, used for `prisma db push` / migrations.
# With Neon/Supabase use the unpooled host; otherwise same as DATABASE_URL.
DIRECT_URL="postgresql://user:password@localhost:5432/nmta?schema=public"

# --- Operator (back office) auth ---
# Single-operator password login for v1. Set a strong value in .env.
OPERATOR_PASSWORD="change-me"
# Secret used to sign the operator session cookie (any long random string).
SESSION_SECRET="change-me-to-a-long-random-string"

# --- App ---
# Public base URL, used for DocuSign redirect + webhook URLs.
APP_BASE_URL="http://localhost:3000"

# --- DocuSign (leave blank to run in MOCK mode) ---
# When these are unset/blank the app uses a built-in mock e-sign provider that
# still records signer IP + a fake envelope, so the whole flow is testable
# without DocuSign credentials. Fill these in for real envelopes.
DOCUSIGN_INTEGRATION_KEY=""
DOCUSIGN_USER_ID=""
DOCUSIGN_ACCOUNT_ID=""
# RSA private key (PEM). Use \n-escaped single line, or point to a file path.
DOCUSIGN_PRIVATE_KEY=""
# demo: account-d.docusign.com | prod: account.docusign.com
DOCUSIGN_AUTH_SERVER="account-d.docusign.com"
# demo: https://demo.docusign.net/restapi | prod: https://www.docusign.net/restapi
DOCUSIGN_BASE_PATH="https://demo.docusign.net/restapi"
# Shared secret configured on the DocuSign Connect webhook (HMAC verification).
DOCUSIGN_CONNECT_HMAC_KEY=""
